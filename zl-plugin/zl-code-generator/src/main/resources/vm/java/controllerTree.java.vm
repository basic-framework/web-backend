package ${packageName}.controller;

import com.zl.common.result.Result;
import ${packageName}.domain.${ClassName};
import ${packageName}.dto.${ClassName}Dto;
import ${packageName}.service.${ClassName}Service;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.tags.Tag;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

import java.util.List;

/**
 * ${functionName}控制器（树表）
 *
 * @author ${author}
 * @date ${datetime}
 */
@RestController
@RequestMapping("/${moduleName}/${classname}")
@Tag(name = "${functionName}管理", description = "${functionName}管理接口")
@Slf4j
public class ${ClassName}Controller {

    @Autowired
    private ${ClassName}Service ${classname}Service;

    /**
     * 查询所有列表
     *
     * @return 列表
     */
    @GetMapping("/list")
    @Operation(summary = "查询列表")
    public Result<List<${ClassName}>> list() {
        List<${ClassName}> list = ${classname}Service.findAll();
        return Result.success(list);
    }

    /**
     * 查询树形结构
     *
     * @return 树形结构列表
     */
    @GetMapping("/tree")
    @Operation(summary = "查询树形结构")
    public Result<List<${ClassName}>> tree() {
        List<${ClassName}> tree = ${classname}Service.findTree();
        return Result.success(tree);
    }

    /**
     * 根据父节点ID查询树形结构
     *
     * @param parentId 父节点ID
     * @return 树形结构列表
     */
    @GetMapping("/tree/{parentId}")
    @Operation(summary = "根据父节点ID查询树形结构")
    public Result<List<${ClassName}>> treeByParentId(@PathVariable Long parentId) {
        List<${ClassName}> tree = ${classname}Service.findTreeByParentId(parentId);
        return Result.success(tree);
    }

    /**
     * 根据ID查询
     *
     * @param id ID
     * @return 对象
     */
    @GetMapping("/{id}")
    @Operation(summary = "根据ID查询")
    public Result<${ClassName}> getById(@PathVariable Long id) {
        ${ClassName} ${classname} = ${classname}Service.findById(id);
        return Result.success(${classname});
    }

    /**
     * 创建
     *
     * @param ${classname}Dto 数据传输对象
     * @return 是否成功
     */
    @PostMapping
    @Operation(summary = "创建")
    public Result<Boolean> create(@RequestBody ${ClassName}Dto ${classname}Dto) {
        Boolean flag = ${classname}Service.create(${classname}Dto);
        return Result.success(flag);
    }

    /**
     * 更新
     *
     * @param ${classname}Dto 数据传输对象
     * @return 是否成功
     */
    @PutMapping
    @Operation(summary = "更新")
    public Result<Boolean> update(@RequestBody ${ClassName}Dto ${classname}Dto) {
        Boolean flag = ${classname}Service.update(${classname}Dto);
        return Result.success(flag);
    }

    /**
     * 根据ID删除
     *
     * @param id ID
     * @return 是否成功
     */
    @DeleteMapping("/{id}")
    @Operation(summary = "删除")
    public Result<Boolean> delete(@PathVariable Long id) {
        Boolean flag = ${classname}Service.deleteById(id);
        return Result.success(flag);
    }

    /**
     * 移动节点
     *
     * @param id 节点ID
     * @param newParentId 新的父节点ID
     * @return 是否成功
     */
    @PutMapping("/move/{id}/{newParentId}")
    @Operation(summary = "移动节点")
    public Result<Boolean> moveNode(@PathVariable Long id, @PathVariable Long newParentId) {
        Boolean flag = ${classname}Service.moveNode(id, newParentId);
        return Result.success(flag);
    }
}
